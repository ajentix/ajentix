# --- ajentix monorepo, repo-wide ignores ------------------------------------------------------
# Large / regenerable data caches and generated reports — NEVER commit (see README "Large files").
**/data/cache/
**/data/realrun/
**/data/realrun_full/
**/data/full_chunks/
**/reports/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# GJC workflow runtime state (planning artifacts kept local)
.gjc/

# AI coding agents & editor state — local only, NEVER commit (leak local paths, chat history,
# or MCP/API keys). Force-add a specific file only if you deliberately want to share it.
.claude/
.codex/
.cursor/
.aider*
.specstory/
.continue/
.windsurf/
.cody/
.tabnine/
.mcp.json
.vscode/
.idea/
.ipynb_checkpoints/

# Secrets — NEVER commit (object-storage creds, webhook URLs, keys)
.env
*.key
*.pem
secrets/

# OS
.DS_Store

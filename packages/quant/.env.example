# ajentix-quant configuration (copy to .env; .env is gitignored)
# All settings use the AQ_ prefix.

# --- Venue (v1 = Bybit via ccxt) ---
AQ_VENUE=bybit
# API keys MUST be TRADE-ONLY. NEVER grant withdrawal permission.
AQ_BYBIT_API_KEY=
AQ_BYBIT_API_SECRET=

# --- Capital (range, not fixed) ---
AQ_CAPITAL_USD_MIN=500
AQ_CAPITAL_USD_MAX=2000

# --- Risk / dynamic leverage ---
AQ_BASE_LEVERAGE=2.0
AQ_MAX_LEVERAGE=5.0
AQ_MIN_LIQ_DISTANCE_PCT=0.15
AQ_RESERVE_PCT=0.25
AQ_MAX_DRAWDOWN_PCT=0.05
AQ_FUNDING_REVERSAL_EXIT_HOURS=24
AQ_MAX_POSITION_PCT=0.25

# --- Strategy ---
# Minimum 8h funding rate (fractional) to enter the delta-neutral carry. 0.0001 = 0.01%/8h
AQ_MIN_FUNDING_RATE_8H=0.0001
